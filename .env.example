# Example environment variables (DO NOT COMMIT REAL TOKENS)

# Cloudflare account & token for Images uploads
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Replicate (or other AI image provider) API token
REPLICATE_API_TOKEN=

# Alternate fallbacks supported by code (optional)
CF_ACCOUNT_ID=
CF_API_TOKEN=
CLOUDFLARE_REPLICATE_API_TOKEN=
CF_REPLICATE_TOKEN=
